<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Forgot Password</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      background:linear-gradient(135deg,#ff9a9e,#fad0c4);
    }

    .container{
      width:380px;
      background:white;
      padding:40px;
      border-radius:20px;
      box-shadow:0 10px 30px rgba(0,0,0,0.2);
    }

    .container h1{
      text-align:center;
      color:#333;
      margin-bottom:10px;
    }

    .container p{
      text-align:center;
      color:gray;
      margin-bottom:25px;
      line-height:1.5;
    }

    .input-box{
      margin-bottom:20px;
    }

    .input-box label{
      display:block;
      margin-bottom:8px;
      font-weight:bold;
      color:#444;
    }

    .input-box input{
      width:100%;
      padding:12px;
      border:1px solid #ccc;
      border-radius:10px;
      outline:none;
      font-size:15px;
      transition:0.3s;
    }

    .input-box input:focus{
      border-color:#ff758c;
      box-shadow:0 0 5px rgba(255,117,140,0.5);
    }

    .reset-btn{
      width:100%;
      padding:12px;
      border:none;
      border-radius:10px;
      background:#ff758c;
      color:white;
      font-size:16px;
      cursor:pointer;
      transition:0.3s;
    }

    .reset-btn:hover{
      background:#ff5277;
    }

    .message{
      margin-top:15px;
      text-align:center;
      font-weight:bold;
    }

    .error{
      color:red;
      font-size:14px;
      margin-top:5px;
    }

    .success{
      color:green;
    }

    .bottom-text{
      text-align:center;
      margin-top:20px;
      color:#666;
    }

    .bottom-text a{
      text-decoration:none;
      color:#ff758c;
      font-weight:bold;
    }
    .message{
  margin-top:15px;
  text-align:center;
  font-weight:bold;
  font-size:15px;
}

  </style>

</head>

<body>

  <div class="container">

    <h1>Forgot Password?</h1>

    <p>
      Enter your registered email address.<br>
      We will send you a password reset link.
    </p>

    <form action="/forgot" method="POST" id="forgotForm">

      <div class="input-box">

        <label>Email Address</label>

        <input
          type="email"
          id="email"
          name="email"
          placeholder="Enter your email"
        >

        <div class="error" id="emailError"></div>

      </div>

      <button class="reset-btn">
        Send Reset Link
      </button>

      <div class="message" id="message"></div>

    </form>

    <div class="bottom-text">
      Remember your password?
      <a href="/login">Login</a>
    </div>

  </div>

  <script>

const form =
document.getElementById("forgotForm");

form.addEventListener("submit",
async function(e){

  e.preventDefault();

  const email =
  document.getElementById("email").value.trim();

  const emailError =
  document.getElementById("emailError");

  const message =
  document.getElementById("message");

  emailError.innerHTML = "";
  message.innerHTML = "";

  if(email === ""){

    emailError.innerHTML =
    "Email is required";

    return;
  }

  try{

    const response = await fetch("/forgot",{

      method:"POST",

      headers:{
        "Content-Type":"application/json"
      },

      body:JSON.stringify({ email })

    });

    const data =
    await response.json();

    message.innerHTML =
    data.message;

    if(data.success){

      message.style.color =
      "green";

    }else{

      message.style.color =
      "red";
    }

  }

  catch(err){

    message.innerHTML =
    "Server Error ❌";

    message.style.color =
    "red";
  }

});

</script>

</body>
</html>