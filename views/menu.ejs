          image:"https://images.unsplash.com/photo-1567188040759-fb8a883dc6d8?q=80&w=1000&auto=format&fit=crop"
        },

        {
          name:"Noodles",
          price:"₹199",
          image:"https://images.unsplash.com/photo-1612929633738-8fe44f7ec841?q=80&w=1000&auto=format&fit=crop"
        },

        {
          name:"Tacos",
          price:"₹240",
          image:"https://images.unsplash.com/photo-1552332386-f8dd00dc2f85?q=80&w=1000&auto=format&fit=crop"
        },

