<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>QuickBite Cart</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      background:#e9dbc6;
      min-height:100vh;
    display:flex;
    flex-direction:column;
    }

    /* Navbar */

    nav{
      background:#e9dbc6;
      color:black;

      padding:15px 8%;

      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    nav h1{
      font-size:30px;
    }

    nav ul{
      display:flex;
      list-style:none;
      gap:25px;
    }

    nav ul li{
      cursor:pointer;
      transition:0.3s;
    }

    nav ul li:hover{
      color:#c09061;
    }

    /* Cart Section */

    .cart-section{
      padding:50px 8%;
    }

    .cart-section h2{
      text-align:center;
      margin-bottom:40px;
      font-size:40px;
      color:#111827;
    }

    /* Cart Container */

    .cart-container{
      display:flex;
      flex-wrap:wrap;
      gap:30px;
    }

    /* Cart Items */

    .cart-items{
      flex:2;
    }

    .cart-card{
      background:wheat;

      display:flex;
      align-items:center;

      gap:20px;

      padding:20px;

      border-radius:15px;

      margin-bottom:20px;

      box-shadow:0 5px 15px rgba(0,0,0,0.1);
    }

    .cart-card img{
      width:140px;
      height:120px;
      object-fit:cover;
      border-radius:10px;
    }

    .cart-info{
      flex:1;
    }

    .cart-info h3{
      margin-bottom:10px;
      color:#111827;
    }

    .cart-info p{
      color:gray;
      margin-bottom:10px;
    }

    .price{
      color:#4e3002;
      font-size:22px;
      font-weight:bold;
    }

    /* Quantity Buttons */

    .quantity{
      display:flex;
      align-items:center;
      gap:10px;
      margin-top:10px;
    }

    .quantity button{
      width:35px;
      height:35px;

      border:none;

      border-radius:50%;

      background:#111827;

      color:white;

      font-size:18px;

      cursor:pointer;
    }

    .remove-btn{
      margin-top:15px;

      padding:10px 15px;

      border:none;

      background:black;

      color:white;

      border-radius:8px;

      cursor:pointer;

      transition:0.3s;
    }

    .remove-btn:hover{
      background:black;
    }

    /* Summary */

    .summary{
      flex:1;

      background:#f4c393;

      padding:30px;

      border-radius:15px;

      height:fit-content;

      box-shadow:0 5px 15px rgba(0,0,0,0.1);
    }

    .summary h3{
      margin-bottom:25px;
      color:#111827;
      font-size:28px;
    }

    .summary p{
      display:flex;
      justify-content:space-between;

      margin-bottom:20px;

      font-size:18px;
    }

    .checkout-btn{
      width:100%;

      padding:15px;

      border:none;

      background:#eda539;

      color:#111827;

      font-size:18px;

      font-weight:bold;

      border-radius:10px;

      cursor:pointer;

      transition:0.3s;
    }

    .checkout-btn:hover{
      transform:scale(1.03);
    }

    /* Footer */

    footer{
    margin-top:auto;
    background:#e9dbc6;
    color:black;
    text-align:center;
    padding:2%;
}

    /* Responsive */

    @media(max-width:900px){

      .cart-container{
        flex-direction:column;
      }

      .cart-card{
        flex-direction:column;
        text-align:center;
      }

    }
    .home1-icon{
      text-decoration:none;
      color:rgb(12, 4, 4);
    }

  </style>

</head>

<body>

  <!-- Navbar -->

  <nav>

    <h1><a href="\api\home" class="home1-icon">QuickBite</a></h1>

    <ul>
      <li><a href="\api\menu" class="home1-icon">Menu</a></li>
    </ul>

  </nav>

  <!-- Cart Section -->

  <section class="cart-section">

    <h2>Your Orders</h2>

    <div class="cart-container">

      <!-- Cart Items -->

      <div class="cart-items">
        <!-- Item 1 -->

        <div class="cart-card">

          <img
          src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=1000&auto=format&fit=crop"
          alt="Burger">

          <div class="cart-info">

            <h3>Cheese Burger</h3>

            <p>
              Delicious burger with extra cheese.
            </p>

            <div class="price">
              ₹199
            </div>

            <div class="quantity">

              <button class="minus">
                -
              </button>

              <span class="count">
                1
              </span>

              <button class="plus">
                +
              </button>

            </div>

            <button class="remove-btn">
              Remove
            </button>

          </div>

        </div>

        <!-- Item 2 -->

        <div class="cart-card">

          <img
          src="https://images.unsplash.com/photo-1513104890138-7c749659a591?q=80&w=1000&auto=format&fit=crop"
          alt="Pizza">

          <div class="cart-info">

            <h3>Italian Pizza</h3>

            <p>
              Crispy pizza with cheese topping.
            </p>

            <div class="price">
              ₹299
            </div>

            <div class="quantity">

              <button class="minus">
                -
              </button>

              <span class="count">
                1
              </span>

              <button class="plus">
                +
              </button>

            </div>

            <button class="remove-btn">
              Remove
            </button>

          </div>

        </div>

      </div>

      <!-- Summary -->

      <div class="summary">

        <h3>Order Summary</h3>

        <p>
          <span>Items Total</span>
          <span id="itemsTotal">₹498</span>
        </p>

        <p>
          <span>Delivery Fee</span>
          <span>₹50</span>
        </p>

        <p>
          <span><strong>Total</strong></span>
          <span id="finalTotal">
            <strong>₹548</strong>
          </span>
        </p>

        <button class="checkout-btn">
          Proceed To Checkout
        </button>

      </div>

    </div>

  </section>

  <!-- Footer -->

  <footer>

    <p>
      © 2026 QuickBite | All Rights Reserved
    </p>

  </footer>

  <script>

    // Quantity Increase/Decrease

    const plusBtns =
    document.querySelectorAll(".plus");

    const minusBtns =
    document.querySelectorAll(".minus");

    const counts =
    document.querySelectorAll(".count");

    plusBtns.forEach((btn,index)=>{

      btn.addEventListener("click",function(){

        let count =
        parseInt(counts[index].innerHTML);

        count++;

        counts[index].innerHTML = count;

      });

    });

    minusBtns.forEach((btn,index)=>{

      btn.addEventListener("click",function(){

        let count =
        parseInt(counts[index].innerHTML);

        if(count > 1){

          count--;

          counts[index].innerHTML = count;

        }

      });

    });

    // Remove Item

    const removeBtns =
    document.querySelectorAll(".remove-btn");

    removeBtns.forEach((btn)=>{

      btn.addEventListener("click",function(){

        btn.parentElement.parentElement.remove();

        alert("Item Removed ");

      });

    });

    // Checkout Button

    const checkoutBtn =
    document.querySelector(".checkout-btn");

    checkoutBtn.addEventListener("click",function(){

      alert("Proceeding To Payment ");

    });

  </script>

</body>
</html>