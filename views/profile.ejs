<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Profile Page</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:#e9dbc6;
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
}

.profile-card{
    width:800px;
    background:rgb(234, 195, 122);;
    border-radius:20px;
    padding:30px;
    text-align:center;
    box-shadow:0 10px 30px rgba(0,0,0,0.1);
}

.profile-img{
    width:130px;
    height:130px;
    border-radius:50%;
    object-fit:cover;
    border:4px ;
    margin-bottom:15px;
}

h2{
    margin-bottom:10px;
}

.info{
    margin-top:20px;
    text-align:left;
}

.info p{
    margin:12px 0;
    padding:10px;
    background:wheat;;
    border-radius:10px;
}

.edit-btn{
    margin-top:20px;
    padding:12px 25px;
    border:none;
    background:rgb(235, 176, 65);
    color:black;
    border-radius:30px;
    cursor:pointer;
    transition:0.3s;
}

.edit-btn:hover{
    transform:scale(1.05);
}

.save-btn{
    display:none;
    margin-top:10px;
    padding:12px 25px;
    border:none;
    background:#28a745;
    color:white;
    border-radius:30px;
    cursor:pointer;
}

</style>
</head>
<body>

<div class="profile-card">

    <img src="\user.png"
         class="profile-img"
         id="profileImg">

    <h2 id="nameText">Sarachandra</h2>

    <div class="info">

        <p id="emailText">
            Email: sarachandra@gmail.com
        </p>

        <p id="phoneText">
            Phone: +91 9876543210
        </p>

        <p id="locationText">
            Location: Vijayawada, Andhra Pradesh
        </p>

    </div>

    <button class="edit-btn"
            >
        Edit Profile
    </button>
</div>
</body>
</html>