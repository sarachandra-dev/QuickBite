<!DOCTYPE html>
<html>
<head>
  <title>Verify OTP</title>
</head>
<body>

<h1>Verify OTP</h1>

<form action="/verify-otp" method="POST">

  <input
    type="hidden"
    name="email"
    value="<%= email %>"
  >

  <input
    type="text"
    name="otp"
    placeholder="Enter OTP"
    required
  >

  <button type="submit">
    Verify OTP
  </button>

</form>

</body>
</html>